<%
const body = `
<nav class="breadcrumb animate-fade">
  <a href="/projects">/</a><span>/</span><span>${project.name}</span>
</nav>

<section class="hero-card animate-fade" style="animation-delay:.05s">
  <div>
    <div class="page-title">/ ${project.name}</div>
    <div class="page-desc" data-i18n="manage_resources">${t('manage_resources')}</div>
    <div class="endpoint-box">
      <div class="endpoint-label" data-i18n="api_base">${t('api_base')}</div>
      <div class="endpoint-value">
        <span id="api-endpoint">${apiBase}</span>
        <button type="button" class="btn-copy" onclick="copyApiEndpoint()" title="Copy">📋</button>
      </div>
    </div>
  </div>
</section>

<section class="panel animate-fade" style="animation-delay:.1s">
  <div class="panel-title" data-i18n="project_settings">${t('project_settings')}</div>
  <form method="post" action="/projects/${project.id}/save" class="stack-lg">
    <div class="grid-2 grid-2--wide">
      <label class="field">
        <span class="field-label" data-i18n="project_name">${t('project_name')}</span>
        <span class="input-wrap"><input class="ui-input" name="name" value="${project.name.replace(/"/g,'&quot;')}" readonly style="opacity:0.6;cursor:not-allowed" /></span>
      </label>
      <label class="field">
        <span class="field-label" data-i18n="api_prefix_field">${t('api_prefix_field')}</span>
        <span class="input-wrap"><input class="ui-input" name="apiPrefix" value="${(project.apiPrefix || '').replace(/"/g,'&quot;')}" placeholder="e.g. api/v1" /></span>
      </label>
    </div>
    <div class="actions-row">
      <button class="ui-button" type="submit" data-i18n="save_button">${t('save_button')}</button>
      <button class="ui-button ui-button--danger" type="button" onclick="showModal()"><span data-i18n="delete_project">${t('delete_project')}</span></button>
    </div>
  </form>
</section>

<section class="section-head animate-fade" style="animation-delay:.15s">
  <div class="panel-title" style="margin:0">/ <span data-i18n="resources">${t('resources')}</span></div>
  <a class="ui-button" href="/projects/${project.id}/resources/new">+ <span data-i18n="add_resource">${t('add_resource')}</span></a>
</section>

<div id="modal-overlay" class="modal-overlay" onclick="closeModal(event)">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div class="modal-title" id="modal-title"></div>
    <div class="modal-body" id="modal-body"></div>
    <div class="modal-actions">
      <button class="ui-button ui-button--ghost" onclick="closeModal()"><span data-i18n="back">${t('back')}</span></button>
      <button class="ui-button ui-button--danger" id="modal-confirm" onclick="confirmModal()"></button>
    </div>
  </div>
</div>
<form id="delete-form" method="post" action="/projects/${project.id}/delete" style="display:none"></form>
<form id="delete-resource-form" method="post" style="display:none"></form>

${resources.length ? `
<section class="card-grid">
${resources.map((resource, i) => `
  <article class="card card--hover animate-fade" style="animation-delay:${(i+2)*.05}s">
    <div class="card-head">
      <div>
        <div class="card-title">${resource.label || resource.name}</div>
        <div class="card-sub">${resource.name}</div>
      </div>
      <span class="tag">${resource.count}&nbsp;<span data-i18n="rows">${t('rows')}</span></span>
    </div>
    <div class="meta-list">
      <div><span data-i18n="parent">${t('parent')}</span>${resource.parentResource || "—"}</div>
      <div><span data-i18n="fields">${t('fields')}</span>${resource.fields.length}</div>
    </div>
    <div class="actions-row actions-row--tight">
      <a class="ui-button ui-button--ghost" href="/projects/${project.id}/resources/${resource.name}/data"><span data-i18n="resource_data">${t('resource_data')}</span></a>
      <a class="ui-button ui-button--ghost" href="/projects/${project.id}/resources/${resource.name}/edit"><span data-i18n="resource_fields">${t('resource_fields')}</span></a>
      <a class="ui-button ui-button--ghost" href="/projects/${project.id}/resources/${resource.name}/docs"><span data-i18n="resource_api">${t('resource_api')}</span></a>
      <button class="ui-button ui-button--danger" type="button" onclick="showDeleteResourceModal('${resource.name}', '${resource.label || resource.name}')"><span data-i18n="delete">${t('delete')}</span></button>
    </div>
  </article>
`).join("")}
</section>
` : `<section class="empty-state animate-fade" style="animation-delay:.2s" data-i18n="no_resources">${t('no_resources')}</section>`}

<section class="section-head animate-fade" style="animation-delay:.25s">
  <div class="panel-title" style="margin:0">/ <span data-i18n="kvs">${t('kvs')}</span></div>
  <a class="ui-button" href="/projects/${project.id}/kvs/new">+ <span data-i18n="add_kv">${t('add_kv')}</span></a>
</section>

<form id="delete-kv-form" method="post" style="display:none"></form>

${kvs.length ? `
<section class="kv-list animate-fade" style="animation-delay:.25s">
  <div class="kv-list-head">
    <span data-i18n="key_field">${t('key_field')}</span>
    <span>描述</span>
    <span data-i18n="field_type" style="text-align:center">${t('field_type')}</span>
    <span data-i18n="value_field">${t('value_field')}</span>
  </div>
${kvs.map((kv, i) => {
  const type = kv.fields?.[0]?.type || 'string';
  const val = kv.value?.value;
  let displayVal = '';
  if (type === 'boolean') displayVal = val ? 'TRUE' : 'FALSE';
  else if (type === 'object') displayVal = typeof val === 'object' ? JSON.stringify(val) : String(val);
  else if (type === 'array') displayVal = Array.isArray(val) ? JSON.stringify(val) : String(val);
  else displayVal = String(val);
  return `
  <div class="kv-list-item">
    <span class="kv-name">${kv.name}</span>
    <span class="kv-desc">${kv.desc || ''}</span>
    <span class="tag tag--small" style="text-align:center">${type}</span>
    <code class="kv-list-value">${displayVal.length > 50 ? displayVal.substring(0, 50) + '...' : displayVal}</code>
    <div class="kv-list-actions">
      <a class="btn-icon" href="/projects/${project.id}/kvs/${kv.name}/edit" title="编辑">✎</a>
      <button class="btn-icon btn-danger" type="button" onclick="showDeleteKvModal('${kv.name}')">×</button>
    </div>
  </div>
`;
}).join('')}
</section>
` : `<section class="empty-state animate-fade" style="animation-delay:.3s" data-i18n="no_kvs">${t('no_kvs')}</section>`}

<style>
.kv-list {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.kv-list-head {
  display: grid;
  grid-template-columns: 1fr 1fr 70px 1fr 60px;
  gap: 8px;
  padding: 8px 12px;
  background: var(--surface-2);
  border-bottom: 1px solid var(--border);
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--text-dim);
}
.kv-list-item {
  display: grid;
  grid-template-columns: 1fr 1fr 70px 1fr 60px;
  gap: 8px;
  align-items: center;
  padding: 6px 12px;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}
.kv-list-item:last-child { border-bottom: none; }
.kv-list-item:hover { background: var(--surface-2); }
.kv-name { font-size: 14px; font-weight: 700; color: var(--text); }
.kv-desc { font-size: 12px; color: var(--text-muted); }
.kv-list-value {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-dim);
  background: var(--surface-2);
  padding: 2px 6px;
  border-radius: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200px;
}
.kv-list-path {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--accent);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.kv-list-actions {
  display: flex;
  gap: 6px;
  justify-content: center;
}
.btn-icon {
  padding: 4px 8px;
  font-size: 14px;
  color: var(--text-dim);
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: 3px;
  cursor: pointer;
  text-decoration: none;
  display: inline-block;
}
.btn-icon:hover {
  color: var(--text);
  background: var(--surface);
  border-color: var(--accent);
}
.btn-icon.btn-danger {
  color: var(--text-dim);
}
.btn-icon.btn-danger:hover {
  color: #fff;
  background: #d32f2f;
  border-color: #d32f2f;
}
.kv-list-item:hover .kv-list-actions { opacity: 1; }
.kv-list-actions .ui-button { padding: 4px 8px; font-size: 11px; }
</style>

<script>
var modalCallback = null;

function copyApiEndpoint() {
  var text = document.getElementById('api-endpoint').textContent;
  navigator.clipboard.writeText(text).then(function() {
    var btn = document.querySelector('.btn-copy');
    btn.textContent = '✓';
    btn.classList.add('copied');
    setTimeout(function() {
      btn.textContent = '📋';
      btn.classList.remove('copied');
    }, 1500);
  });
}

function showModal() {
  var title = document.querySelector('.modal-title');
  var body = document.querySelector('.modal-body');
  var confirmBtn = document.getElementById('modal-confirm');
  var locale = localStorage.getItem('locale') || 'zh';
  title.textContent = locale === 'zh' ? '确认删除项目' : 'Confirm Delete';
  body.textContent = locale === 'zh' ? '确定要删除此项目吗？此操作不可恢复！' : 'Are you sure you want to delete this project? This cannot be undone!';
  confirmBtn.textContent = locale === 'zh' ? '确认删除' : 'Delete';
  modalCallback = function() {
    document.getElementById('delete-form').submit();
  };
  document.getElementById('modal-overlay').style.display = 'flex';
}

function showDeleteResourceModal(name, label) {
  var title = document.querySelector('.modal-title');
  var body = document.querySelector('.modal-body');
  var confirmBtn = document.getElementById('modal-confirm');
  var locale = localStorage.getItem('locale') || 'zh';
  title.textContent = locale === 'zh' ? '确认删除资源' : 'Confirm Delete Resource';
  body.textContent = locale === 'zh' ? '确定删除资源「' + label + '」吗？此操作不可恢复！' : 'Delete resource "' + label + '"? This cannot be undone!';
  confirmBtn.textContent = locale === 'zh' ? '确认删除' : 'Delete';
  var form = document.getElementById('delete-resource-form');
  form.action = '/projects/${project.id}/resources/' + name + '/delete';
  modalCallback = function() {
    form.submit();
  };
  document.getElementById('modal-overlay').style.display = 'flex';
}

function showDeleteKvModal(name) {
  var title = document.querySelector('.modal-title');
  var body = document.querySelector('.modal-body');
  var confirmBtn = document.getElementById('modal-confirm');
  var locale = localStorage.getItem('locale') || 'zh';
  title.textContent = locale === 'zh' ? '确认删除KV' : 'Confirm Delete KV';
  body.textContent = locale === 'zh' ? '确定删除KV「' + name + '」吗？此操作不可恢复！' : 'Delete KV "' + name + '"? This cannot be undone!';
  confirmBtn.textContent = locale === 'zh' ? '确认删除' : 'Delete';
  var form = document.getElementById('delete-kv-form');
  form.action = '/projects/${project.id}/kvs/' + name + '/delete';
  modalCallback = function() {
    form.submit();
  };
  document.getElementById('modal-overlay').style.display = 'flex';
}

function closeModal(e) {
  if (e && e.target !== e.currentTarget) return;
  document.getElementById('modal-overlay').style.display = 'none';
}

function confirmModal() {
  if (modalCallback) modalCallback();
}
</script>
`;
%>
<%- include('layout', { title: t('project_settings'), body }) %>