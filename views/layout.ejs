<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/style.css" />
  <script>
    (function() {
      const theme = localStorage.getItem('theme') || 'cyber-green';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <div class="brand">
        <a href="/projects" class="brand-link">
          <div class="brand-mark">B</div>
          <div>
            <div class="brand-title" data-i18n="brand_title">BOS配置中心</div>
            <div class="brand-sub" id="brand-sub" data-i18n="brand_sub">本地配置中心</div>
          </div>
        </a>
      </div>
      <nav class="top-actions">
        <div class="lang-toggle">
          <button onclick="setLocale('zh')" data-locale="zh" class="lang-btn">中</button>
          <button onclick="setLocale('en')" data-locale="en" class="lang-btn">EN</button>
        </div>
        <div class="theme-toggle">
          <button onclick="setTheme('cyber-green')" data-theme-btn="cyber-green" title="Cyber Green">G</button>
          <button onclick="setTheme('cyber-red')" data-theme-btn="cyber-red" title="Cyber Red">R</button>
          <button onclick="setTheme('light')" data-theme-btn="light" title="Light">L</button>
        </div>
        <a class="ui-button ui-button--ghost" href="/projects" style="margin-left:8px" data-i18n="projects">PROJ</a>
        <a class="ui-button ui-button--ghost" href="/logout" style="margin-left:8px" data-i18n="logout">LOGOUT</a>
      </nav>
    </header>
    <main class="page">
      <%- body %>
    </main>
    <footer class="footer">
      <span data-i18n="copyright">&copy; BOS Cloud</span>
    </footer>
  </div>
  <script src="/public/i18n.js"></script>
  <script>
    // Apply brand subtitle translation
    window.addEventListener('localeChanged', function(e) {
      document.getElementById('brand-sub').textContent = e.detail.locale === 'zh' ? i18n.zh.brand_sub : i18n.en.brand_sub;
    });
    if (localStorage.getItem('locale') === 'en') {
      document.getElementById('brand-sub').textContent = i18n.en.brand_sub;
    }

    function setTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      document.querySelectorAll('[data-theme-btn]').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.themeBtn === theme);
      });
    }
    document.querySelectorAll('[data-theme-btn]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.themeBtn === (localStorage.getItem('theme') || 'cyber-green'));
    });

    // Initialize language buttons
    (function() {
      var savedLocale = localStorage.getItem('locale') || 'zh';
      document.querySelectorAll('[data-locale]').forEach(function(btn) {
        btn.classList.toggle('active', btn.dataset.locale === savedLocale);
      });
    })();
  </script>
</body>
</html>